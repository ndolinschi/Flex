{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flex",
  "version": "0.1.0",
  "identifier": "com.ndolinschi.agentloop.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flex",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "backgroundColor": "#141414",
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDNDQ4QUY1NTY0QTdFMUQKUldRZGZrcFc5WXBFVEFLdnBxMDNJbE5GWFJzaDgwOVBxaDdwL3dkT1VnUlJoTDhXVmlkMFYxaTYK",
      "endpoints": [
        "https://github.com/ndolinschi/Flex/releases/latest/download/latest.json"
      ]
    }
  }
}
